# =========================
# Common
# =========================
CONTAINER_TZ=Asia/Shanghai

# =========================
# Nginx reverse proxy
# FRONTEND_MODE:
#   static -> serve files from deploy/docker/nginx/html
#   dev    -> proxy to the frontend dev server started from IDE
# =========================
NGINX_HTTP_PORT=9010
FRONTEND_MODE=static
FRONTEND_DEV_SERVER=http://host.docker.internal:9510
GATEWAY_SERVER=http://host.docker.internal:9008

# =========================
# Frontend local learning
# These values are convenient when you start the frontend in WebStorm / VS Code.
# =========================
FRONTEND_DEV_PORT=9510
FRONTEND_GATEWAY_TARGET=http://host.docker.internal:9008
FRONTEND_ALLOWED_HOSTS=*
FRONTEND_PUBLIC_HOST=
FRONTEND_PUBLIC_PROTOCOL=https

# =========================
# PostgreSQL
# =========================
POSTGRES_HOST_PORT=5432
POSTGRES_IMAGE_TAG=17-alpine
POSTGRES_DB=lottery-platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123456

# =========================
# Redis
# =========================
REDIS_HOST_PORT=6379
REDIS_IMAGE_TAG=7.4-alpine

# =========================
# Nacos
# =========================
NACOS_WEB_PORT=8080
NACOS_SERVER_PORT=8848
NACOS_RPC_PORT=9848
NACOS_IMAGE_TAG=v3.1.1
NACOS_AUTH_TOKEN=YWJjZGVmZ2hpamtsbW5vcHFyc3R1dnd4eXoxMjM0NTY3ODkw
NACOS_AUTH_IDENTITY_KEY=nacos1
NACOS_AUTH_IDENTITY_VALUE=nacos1

# =========================
# Kafka
# =========================
KAFKA_HOST_PORT=9092
KAFKA_IMAGE_TAG=3.9.2
KAFKA_HOST=localhost
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk

# =========================
# RocketMQ
# =========================
ROCKETMQ_NAMESRV_PORT=9876
ROCKETMQ_PROXY_PORT=10909
ROCKETMQ_BROKER_PORT=10911
ROCKETMQ_HA_PORT=10912
ROCKETMQ_IMAGE_TAG=5.3.2

# =========================
# MinIO
# =========================
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_IMAGE_TAG=RELEASE.2025-07-23T15-54-02Z
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# =========================
# Nexus
# =========================
NEXUS_HTTP_PORT=8081
NEXUS_IMAGE_TAG=3.84.1
NEXUS_JAVA_MIN_HEAP=512m
NEXUS_JAVA_MAX_HEAP=512m
NEXUS_JAVA_DIRECT_MEM=512m

# =========================
# Jenkins
# =========================
JENKINS_HTTP_PORT=9200
JENKINS_AGENT_PORT=9201
JENKINS_ADMIN_ID=admin
JENKINS_ADMIN_PASSWORD=123456
JENKINS_IMAGE_TAG=lts-jdk21

# =========================
# Build toolchain
# =========================
MAVEN_VERSION=3.9.11
NODE_MAJOR=22
